# Environment Variables Configuration
# Copy this file to .env and update with your values

# Application
NODE_ENV=development
APP_PORT=3030
APP_URL=http://localhost:3030
APP_NAME="Node Framework"
APP_TIMEZONE=UTC

# Server
SERVER_HTTPS=false
SERVER_SSL_CERT_PATH=
SERVER_SSL_KEY_PATH=

# Database
DB_ENABLED=false
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=database
DB_USERNAME=root
DB_PASSWORD=
DB_LOGGING=false
DB_TIMEZONE=+07:00
DB_SYNC=true
DB_FORCE=false
DB_ALTER=false

# JWT
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Mailer
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_NAME="Node Framework"
MAIL_FROM_EMAIL=noreply@example.com

# File Upload
UPLOAD_MAX_SIZE=52428800
UPLOAD_TEMP_DIR=./tmp

# Logging
LOG_DIR=logs
