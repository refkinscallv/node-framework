<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Node Framework</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">

    <style>
        /* ── TOKENS ── */
        :root {
            --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        [data-theme="dark"] {
            --bg: #080810;
            --bg-2: #0e0e1a;
            --surface: #12121f;
            --surface-2: #1a1a2e;
            --border: rgba(255,255,255,0.07);
            --border-hover: rgba(255,255,255,0.14);
            --text: #f0f0f8;
            --text-2: #8888aa;
            --text-3: #44446a;
            --accent: #6b5ce7;
            --accent-light: #8b7ff0;
            --accent-bg: rgba(107,92,231,0.1);
            --accent-border: rgba(107,92,231,0.25);
            --green: #1ec9a0;
            --amber: #f0a500;
            --red: #e8526b;
            --code-bg: #0a0a16;
            --shadow: rgba(0,0,0,0.6);
            --nav-bg: rgba(8,8,16,0.88);
            --toggle-bg: #1a1a2e;
        }

        [data-theme="light"] {
            --bg: #fafafa;
            --bg-2: #f4f4f8;
            --surface: #ffffff;
            --surface-2: #f0f0f6;
            --border: rgba(0,0,0,0.08);
            --border-hover: rgba(0,0,0,0.16);
            --text: #111128;
            --text-2: #6666880;
            --text-3: #aaaacc;
            --accent: #6b5ce7;
            --accent-light: #5245d4;
            --accent-bg: rgba(107,92,231,0.07);
            --accent-border: rgba(107,92,231,0.2);
            --green: #0da87e;
            --amber: #d48a00;
            --red: #d63f57;
            --code-bg: #f0f0f8;
            --shadow: rgba(0,0,0,0.12);
            --nav-bg: rgba(250,250,250,0.9);
            --toggle-bg: #e8e8f0;
            --text-2: #666688;
        }

        /* ── RESET ── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
            transition: background var(--transition), color var(--transition);
        }

        .mono { font-family: 'DM Mono', monospace; }

        /* ── SUBTLE BG GRID ── */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(var(--border) 1px, transparent 1px),
                linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 64px 64px;
            pointer-events: none;
            z-index: 0;
            transition: background var(--transition);
        }

        /* ── NAV ── */
        nav {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--nav-bg);
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            transition: background var(--transition), border-color var(--transition);
        }

        .nav-inner {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 24px;
            height: 60px;
            display: flex;
            align-items: center;
            gap: 40px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            flex-shrink: 0;
        }

        .logo-mark {
            width: 30px;
            height: 30px;
            background: var(--accent);
            border-radius: 8px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3px;
            padding: 7px;
            transition: transform 0.2s ease;
        }

        .logo:hover .logo-mark { transform: rotate(90deg); }

        .logo-mark span {
            background: white;
            border-radius: 1.5px;
        }

        .logo-mark span:nth-child(2),
        .logo-mark span:nth-child(3) { opacity: 0.5; }

        .logo-name {
            font-size: 14px;
            font-weight: 600;
            color: var(--text);
            letter-spacing: -0.01em;
            transition: color var(--transition);
        }

        .version-pill {
            font-family: 'DM Mono', monospace;
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 999px;
            background: var(--accent-bg);
            color: var(--accent);
            border: 1px solid var(--accent-border);
            transition: background var(--transition), border-color var(--transition);
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 32px;
            margin-left: auto;
        }

        .nav-links a {
            font-size: 13px;
            font-weight: 400;
            color: var(--text-2);
            text-decoration: none;
            transition: color 0.2s;
            letter-spacing: 0.01em;
        }

        .nav-links a:hover { color: var(--text); }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* Theme Toggle */
        .theme-toggle {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: var(--toggle-bg);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            color: var(--text-2);
            flex-shrink: 0;
        }

        .theme-toggle:hover {
            border-color: var(--border-hover);
            color: var(--text);
        }

        .theme-toggle svg { width: 15px; height: 15px; }
        .theme-toggle .icon-sun { display: none; }
        .theme-toggle .icon-moon { display: block; }
        [data-theme="light"] .theme-toggle .icon-sun { display: block; }
        [data-theme="light"] .theme-toggle .icon-moon { display: none; }

        .nav-github {
            display: flex;
            align-items: center;
            gap: 6px;
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            font-weight: 500;
            color: var(--text-2);
            text-decoration: none;
            padding: 7px 14px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: transparent;
            transition: all 0.2s;
        }

        .nav-github:hover {
            border-color: var(--border-hover);
            color: var(--text);
            background: var(--surface);
        }

        /* Mobile nav toggle */
        .mobile-menu-btn {
            display: none;
            width: 36px;
            height: 36px;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: transparent;
            cursor: pointer;
            color: var(--text-2);
            transition: all 0.2s;
        }

        .mobile-menu-btn:hover { color: var(--text); border-color: var(--border-hover); }

        /* ── CONTENT ── */
        .content { position: relative; z-index: 1; }

        /* ── HERO ── */
        .hero {
            min-height: calc(100vh - 60px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 80px 24px 60px;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 999px;
            padding: 6px 14px 6px 10px;
            font-family: 'DM Mono', monospace;
            font-size: 11.5px;
            color: var(--text-2);
            margin-bottom: 40px;
            animation: fadeDown 0.5s ease both;
            transition: background var(--transition), border-color var(--transition), color var(--transition);
        }

        .status-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--green);
            box-shadow: 0 0 6px var(--green);
            animation: statusPulse 2.5s ease infinite;
        }

        @keyframes statusPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        .hero-title {
            font-size: clamp(42px, 8vw, 88px);
            font-weight: 300;
            line-height: 1.0;
            letter-spacing: -0.04em;
            margin-bottom: 24px;
            animation: fadeUp 0.6s 0.1s ease both;
            color: var(--text);
            transition: color var(--transition);
        }

        .hero-title strong {
            font-weight: 600;
            background: linear-gradient(135deg, var(--accent-light) 0%, var(--accent) 60%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-desc {
            max-width: 520px;
            font-size: 16px;
            font-weight: 300;
            color: var(--text-2);
            line-height: 1.7;
            margin-bottom: 40px;
            animation: fadeUp 0.6s 0.2s ease both;
            transition: color var(--transition);
        }

        .hero-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            justify-content: center;
            margin-bottom: 64px;
            animation: fadeUp 0.6s 0.3s ease both;
        }

        /* Buttons */
        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--accent);
            color: #fff;
            font-family: 'DM Mono', monospace;
            font-size: 12.5px;
            font-weight: 500;
            padding: 11px 22px;
            border-radius: 8px;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: all 0.2s ease;
            letter-spacing: 0.01em;
        }

        .btn-primary:hover {
            background: var(--accent-light);
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(107,92,231,0.3);
        }

        .btn-ghost {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: transparent;
            color: var(--text-2);
            font-family: 'DM Mono', monospace;
            font-size: 12.5px;
            font-weight: 500;
            padding: 10px 22px;
            border-radius: 8px;
            text-decoration: none;
            border: 1px solid var(--border);
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-ghost:hover {
            border-color: var(--border-hover);
            color: var(--text);
            transform: translateY(-1px);
        }

        /* Stats strip */
        .stats-strip {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1px;
            background: var(--border);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            width: 100%;
            max-width: 560px;
            animation: fadeUp 0.6s 0.4s ease both;
            transition: background var(--transition), border-color var(--transition);
        }

        .stat {
            background: var(--surface);
            padding: 20px 16px;
            text-align: center;
            transition: background var(--transition);
        }

        .stat-num {
            font-family: 'DM Mono', monospace;
            font-size: 22px;
            font-weight: 500;
            margin-bottom: 4px;
            letter-spacing: -0.02em;
        }

        .stat-label {
            font-size: 11px;
            color: var(--text-2);
            letter-spacing: 0.05em;
            text-transform: uppercase;
            font-weight: 400;
            transition: color var(--transition);
        }

        /* ── SECTION ── */
        section { padding: 100px 24px; }

        .section-inner { max-width: 1100px; margin: 0 auto; }

        .section-tag {
            font-family: 'DM Mono', monospace;
            font-size: 11px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--accent);
            margin-bottom: 16px;
            display: block;
            transition: color var(--transition);
        }

        .section-title {
            font-size: clamp(28px, 4vw, 40px);
            font-weight: 500;
            letter-spacing: -0.025em;
            line-height: 1.15;
            margin-bottom: 16px;
            color: var(--text);
            transition: color var(--transition);
        }

        .section-desc {
            font-size: 15px;
            font-weight: 300;
            color: var(--text-2);
            max-width: 480px;
            line-height: 1.7;
            transition: color var(--transition);
        }

        .divider {
            height: 1px;
            background: var(--border);
            transition: background var(--transition);
        }

        /* ── FEATURES ── */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1px;
            background: var(--border);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            margin-top: 56px;
            transition: background var(--transition), border-color var(--transition);
        }

        .feature-card {
            background: var(--surface);
            padding: 32px 28px;
            transition: background var(--transition);
        }

        .feature-card:hover { background: var(--surface-2); }

        .feature-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: var(--accent-bg);
            border: 1px solid var(--accent-border);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            color: var(--accent);
            transition: background var(--transition), border-color var(--transition);
        }

        .feature-icon svg { width: 16px; height: 16px; }

        .feature-title {
            font-size: 15px;
            font-weight: 500;
            margin-bottom: 8px;
            color: var(--text);
            transition: color var(--transition);
        }

        .feature-desc {
            font-size: 13.5px;
            font-weight: 300;
            color: var(--text-2);
            line-height: 1.65;
            transition: color var(--transition);
        }

        .feature-desc code {
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--accent);
            background: var(--accent-bg);
            padding: 1px 5px;
            border-radius: 4px;
            transition: background var(--transition);
        }

        /* ── QUICKSTART ── */
        .quickstart-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 64px;
            align-items: start;
            margin-top: 56px;
        }

        .steps { display: flex; flex-direction: column; gap: 0; }

        .step {
            display: flex;
            gap: 20px;
            padding: 20px 0;
            border-bottom: 1px solid var(--border);
            transition: border-color var(--transition);
        }

        .step:first-child { padding-top: 0; }
        .step:last-child { border-bottom: none; padding-bottom: 0; }

        .step-num {
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--text-3);
            width: 20px;
            flex-shrink: 0;
            padding-top: 1px;
            transition: color var(--transition);
        }

        .step-body { flex: 1; }

        .step-title {
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
            margin-bottom: 8px;
            transition: color var(--transition);
        }

        .step-cmd {
            font-family: 'DM Mono', monospace;
            font-size: 12.5px;
            color: var(--green);
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 8px 14px;
            border-radius: 7px;
            display: block;
            transition: background var(--transition), border-color var(--transition);
        }

        /* Code blocks */
        .code-block {
            background: var(--code-bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            font-family: 'DM Mono', monospace;
            font-size: 12.5px;
            line-height: 1.75;
            transition: background var(--transition), border-color var(--transition);
        }

        .code-block + .code-block { margin-top: 16px; }

        .code-header {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 16px;
            border-bottom: 1px solid var(--border);
            background: var(--surface);
            transition: background var(--transition), border-color var(--transition);
        }

        .dot { width: 9px; height: 9px; border-radius: 50%; }

        .code-filename {
            font-size: 11px;
            color: var(--text-2);
            margin-left: 4px;
            transition: color var(--transition);
        }

        .code-body {
            padding: 20px 20px;
            overflow-x: auto;
        }

        pre { margin: 0; white-space: pre; }

        .c { color: var(--text-3); }
        .k { color: var(--accent-light); }
        .s { color: var(--amber); }
        .f { color: var(--green); }

        /* ── STACK ── */
        .stack-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 48px;
        }

        .stack-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--text-2);
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 7px 13px;
            transition: all 0.2s;
            cursor: default;
        }

        .stack-pill:hover {
            border-color: var(--accent-border);
            color: var(--text);
            background: var(--accent-bg);
        }

        .stack-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--accent);
            opacity: 0.6;
        }

        /* ── CHANGELOG ── */
        .changelog { display: flex; flex-direction: column; gap: 0; margin-top: 56px; }

        .cl-item {
            display: grid;
            grid-template-columns: 140px 1fr;
            gap: 32px;
            padding: 28px 0;
            border-bottom: 1px solid var(--border);
            align-items: start;
            transition: border-color var(--transition);
        }

        .cl-item:last-child { border-bottom: none; }

        .cl-meta { display: flex; flex-direction: column; gap: 6px; }

        .cl-version {
            font-family: 'DM Mono', monospace;
            font-size: 13.5px;
            font-weight: 500;
            color: var(--text);
            transition: color var(--transition);
        }

        .cl-date {
            font-family: 'DM Mono', monospace;
            font-size: 11px;
            color: var(--text-3);
            transition: color var(--transition);
        }

        .cl-badge {
            display: inline-flex;
            align-items: center;
            font-family: 'DM Mono', monospace;
            font-size: 10px;
            color: var(--green);
            background: rgba(30,201,160,0.1);
            border: 1px solid rgba(30,201,160,0.2);
            border-radius: 4px;
            padding: 2px 7px;
            width: fit-content;
        }

        .cl-desc {
            font-size: 14px;
            font-weight: 300;
            color: var(--text-2);
            line-height: 1.7;
            padding-top: 2px;
            transition: color var(--transition);
        }

        .cl-desc code {
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--accent);
            background: var(--accent-bg);
            padding: 1px 5px;
            border-radius: 4px;
        }

        /* ── FOOTER ── */
        footer {
            padding: 32px 24px;
            border-top: 1px solid var(--border);
            transition: border-color var(--transition);
        }

        .footer-inner {
            max-width: 1100px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
        }

        .footer-left {
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--text-3);
            transition: color var(--transition);
        }

        .footer-right {
            font-size: 12px;
            font-family: 'DM Mono', monospace;
            color: var(--text-3);
            transition: color var(--transition);
        }

        .footer-right a {
            color: var(--accent);
            text-decoration: none;
            transition: opacity 0.2s;
        }

        .footer-right a:hover { opacity: 0.75; }

        /* ── ANIMATIONS ── */
        @keyframes fadeDown {
            from { opacity: 0; transform: translateY(-12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 900px) {
            .features-grid { grid-template-columns: 1fr 1fr; }
            .quickstart-grid { grid-template-columns: 1fr; gap: 40px; }
            .nav-links { display: none; }

            .nav-links.open {
                display: flex;
                flex-direction: column;
                position: fixed;
                top: 60px;
                left: 0;
                right: 0;
                background: var(--nav-bg);
                border-bottom: 1px solid var(--border);
                padding: 16px 24px;
                gap: 16px;
                backdrop-filter: blur(20px);
                z-index: 99;
            }

            .mobile-menu-btn { display: flex; }
        }

        @media (max-width: 620px) {
            .features-grid { grid-template-columns: 1fr; }
            .stats-strip { grid-template-columns: repeat(2, 1fr); }
            .cl-item { grid-template-columns: 1fr; gap: 8px; }
            section { padding: 72px 20px; }
            .hero { padding: 60px 20px 48px; }
        }
    </style>
</head>
<body>

    <!-- ── NAV ── -->
    <nav>
        <div class="nav-inner">
            <a href="#" class="logo">
                <div class="logo-mark">
                    <span></span><span></span><span></span><span></span>
                </div>
                <span class="logo-name">Node Framework</span>
                <span class="version-pill mono">v2.1.0</span>
            </a>

            <div class="nav-links" id="navLinks">
                <a href="#features">Features</a>
                <a href="#quickstart">Quick Start</a>
                <a href="#stack">Stack</a>
                <a href="#changelog">Changelog</a>
            </div>

            <div class="nav-actions">
                <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
                    <!-- Moon -->
                    <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                    <!-- Sun -->
                    <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="5"/>
                        <line x1="12" y1="1" x2="12" y2="3"/>
                        <line x1="12" y1="21" x2="12" y2="23"/>
